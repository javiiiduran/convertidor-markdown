---
/**
 * Página principal: cabecera estática (HTML puro de Astro) + isla React
 * interactiva con toda la lógica de conversión.
 */
import Layout from "../layouts/Layout.astro";
import ConverterApp from "../components/ConverterApp";
---

<Layout title="Convertidor a Markdown — gratis y privado">
  <main class="mx-auto max-w-4xl px-4 py-12">
    <!-- Cabecera (estática, renderizada en build) -->
    <header class="mb-10 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
        Convertidor a <span class="text-sky-500">Markdown</span>
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Arrastra un PDF, documento de Office o imagen y obtén Markdown limpio.
        Gratis para documentos con texto; las imágenes y PDFs escaneados se
        transcriben con la IA de tu elección usando tu propia API key.
      </p>
    </header>

    <!-- Isla React: se hidrata en el cliente -->
    <ConverterApp client:load />

    <!-- Pie con notas de privacidad -->
    <footer class="mt-12 border-t border-slate-200 pt-6 text-center text-xs text-slate-400 dark:border-slate-800 dark:text-slate-500">
      <p>
        🔒 Los archivos se procesan en memoria y nunca se almacenan en el
        servidor. Las API keys viven solo en tu navegador.
      </p>
      <p class="mt-2">
        Proyecto open source ·
        <a
          href="https://github.com/javiiiduran/convertidor-markdown"
          class="underline hover:text-sky-500"
          rel="noopener noreferrer"
          target="_blank">GitHub</a
        >
      </p>
      <p class="mt-3 text-sm text-slate-500 dark:text-slate-400">
        Desarrollado por
        <a
          href="https://www.javiiiduran.com"
          class="font-semibold text-sky-600 underline decoration-sky-300 underline-offset-2 transition hover:text-sky-500 dark:text-sky-400"
          target="_blank"
          rel="noopener noreferrer">Javier Durán</a
        >
      </p>
    </footer>
  </main>
</Layout>
