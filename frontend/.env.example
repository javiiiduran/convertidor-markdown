# ============================================================
# Variables de entorno del frontend (Astro)
# ============================================================
# Copia este archivo a `.env` para desarrollo local:
#   cp .env.example .env
#
# En Vercel: Project Settings > Environment Variables >
#   añade PUBLIC_API_URL con la URL de tu servicio en Render.
# ============================================================

# URL base del backend FastAPI (sin barra final).
#   - Desarrollo local:  http://localhost:8000
#   - Producción:        https://convertidor-markdown-api.onrender.com
PUBLIC_API_URL=http://localhost:8000
